---
import BaseLayout from '../layouts/BaseLayout.astro';
import GlowEffect from '../components/ui/GlowEffect.astro';
---

<BaseLayout
  title="Contact — Xovion Labs"
  description="Book a call or send a message to Xovion Labs. Get help with website builds, CRM setup, AI integrations, or strategy."
>
  <section class="relative overflow-hidden px-4 sm:px-6 pt-16 pb-24">
    <GlowEffect color="blue" position="top-right" />

    <div class="max-w-5xl mx-auto relative z-10">
      <div class="mb-12">
        <p class="text-xs font-mono text-[#58A6FF] uppercase tracking-widest mb-4">Contact</p>
        <h1 class="text-3xl sm:text-4xl font-bold text-[#E6EDF3] mb-4">
          Let's figure out what to build
        </h1>
        <p class="text-[#8B949E] text-lg max-w-xl">
          Two ways to start: book a call and talk it through, or send a message and we'll get back to you within 24 hours.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <!-- Book a Call -->
        <div class="bg-[#161B22] border border-[#21262D] rounded-xl p-8">
          <h2 class="text-lg font-semibold text-[#E6EDF3] mb-2">Book a Call</h2>
          <p class="text-sm text-[#8B949E] mb-6">
            30-minute conversation. No pitch. We'll talk about your business,
            what you're trying to build, and whether we're the right fit.
          </p>
          <!-- Calendly placeholder -->
          <div class="bg-[#0D1117] border border-[#21262D] rounded-lg p-8 text-center">
            <p class="text-xs font-mono text-[#8B949E] mb-4">Calendly embed goes here</p>
            <a
              href="https://calendly.com/xovionlabs"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-6 py-3 bg-[#58A6FF] text-[#0D1117] font-semibold rounded-lg hover:bg-[#79BAFF] transition-colors text-sm"
            >
              📅 Schedule a Time
            </a>
          </div>
        </div>

        <!-- Send a Message -->
        <div class="bg-[#161B22] border border-[#21262D] rounded-xl p-8">
          <h2 class="text-lg font-semibold text-[#E6EDF3] mb-2">Send a Message</h2>
          <p class="text-sm text-[#8B949E] mb-6">
            Prefer async? Fill this out and we'll respond within 24 hours.
          </p>
          <form
            name="contact"
            method="POST"
            action="/contact/success"
            class="space-y-4"
          >
            <div>
              <label for="name" class="block text-xs font-mono text-[#8B949E] mb-1.5">Name</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                placeholder="Your name"
                class="w-full px-4 py-2.5 bg-[#0D1117] border border-[#30363D] rounded-lg text-[#E6EDF3] placeholder-[#8B949E] focus:outline-none focus:border-[#58A6FF] text-sm transition-colors"
              />
            </div>

            <div>
              <label for="email" class="block text-xs font-mono text-[#8B949E] mb-1.5">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="you@company.com"
                class="w-full px-4 py-2.5 bg-[#0D1117] border border-[#30363D] rounded-lg text-[#E6EDF3] placeholder-[#8B949E] focus:outline-none focus:border-[#58A6FF] text-sm transition-colors"
              />
            </div>

            <div>
              <label for="business-type" class="block text-xs font-mono text-[#8B949E] mb-1.5">Business Type</label>
              <select
                id="business-type"
                name="business-type"
                class="w-full px-4 py-2.5 bg-[#0D1117] border border-[#30363D] rounded-lg text-[#E6EDF3] focus:outline-none focus:border-[#58A6FF] text-sm transition-colors appearance-none"
              >
                <option value="" disabled selected>Select your business type</option>
                <option value="real-estate">Real Estate</option>
                <option value="service-business">Service Business</option>
                <option value="saas-tech">SaaS / Tech</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div>
              <label for="need" class="block text-xs font-mono text-[#8B949E] mb-1.5">What do you need?</label>
              <select
                id="need"
                name="need"
                class="w-full px-4 py-2.5 bg-[#0D1117] border border-[#30363D] rounded-lg text-[#E6EDF3] focus:outline-none focus:border-[#58A6FF] text-sm transition-colors appearance-none"
              >
                <option value="" disabled selected>Select a service</option>
                <option value="website-build">Website Build</option>
                <option value="crm-setup">CRM Setup</option>
                <option value="ai-integration">AI Integration</option>
                <option value="strategy-call">Strategy Call</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-xs font-mono text-[#8B949E] mb-1.5">Tell me more</label>
              <textarea
                id="message"
                name="message"
                rows="4"
                placeholder="What are you building? What's the problem you're trying to solve?"
                class="w-full px-4 py-2.5 bg-[#0D1117] border border-[#30363D] rounded-lg text-[#E6EDF3] placeholder-[#8B949E] focus:outline-none focus:border-[#58A6FF] text-sm transition-colors resize-none"
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full px-6 py-3 bg-[#58A6FF] text-[#0D1117] font-semibold rounded-lg hover:bg-[#79BAFF] transition-colors text-sm"
            >
              Send Message
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
