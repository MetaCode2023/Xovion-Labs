---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Book a free call with Xovion Labs. We'll identify where AI automation can save your small business the most time, then build the systems to make it happen.">
  <section class="section-padding">
    <div class="section-container">
      <div class="max-w-2xl mx-auto">
        <!-- Header -->
        <div class="text-center mb-12">
          <span class="tag-blue mb-4 inline-block">Get in Touch</span>
          <h1 class="font-display font-bold text-4xl sm:text-5xl text-xv-text-primary tracking-tight">
            Let's <span class="gradient-text">talk.</span>
          </h1>
          <p class="mt-4 text-xv-text-secondary text-lg">
            No pitch decks. No 47-slide proposals. Just a conversation about what you need and whether we're the right fit.
          </p>
        </div>

        <!-- Two options -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-12">
          <button id="btn-book" onclick="showPanel('book')" class="glass-card rounded-xl p-6 text-center hover:border-xv-accent-blue/40 transition-all group w-full">
            <div class="w-12 h-12 rounded-xl bg-xv-accent-blue/10 border border-xv-accent-blue/20 flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-xv-accent-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
              </svg>
            </div>
            <h3 class="font-display font-semibold text-xv-text-primary group-hover:text-white transition-colors">Book a Free Call</h3>
            <p class="text-sm text-xv-text-secondary mt-1">30-minute strategy conversation</p>
          </button>

          <button id="btn-form" onclick="showPanel('form')" class="glass-card rounded-xl p-6 text-center hover:border-xv-accent-green/40 transition-all group w-full">
            <div class="w-12 h-12 rounded-xl bg-xv-accent-green/10 border border-xv-accent-green/20 flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-xv-accent-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
            </div>
            <h3 class="font-display font-semibold text-xv-text-primary group-hover:text-white transition-colors">Send a Message</h3>
            <p class="text-sm text-xv-text-secondary mt-1">Tell me about your project</p>
          </button>
        </div>

        <!-- Booking embed -->
        <div id="book" class="glass-card rounded-xl p-6 mb-8 hidden">
          <iframe src="https://api.leadconnectorhq.com/widget/booking/eiF739vJXyu1Vok09WSR" style="width: 100%;border:none;overflow: hidden;" scrolling="no" id="eiF739vJXyu1Vok09WSR_1773821432258"></iframe>
          <script src="https://link.msgsndr.com/js/form_embed.js" type="text/javascript"></script>
        </div>

        <!-- Contact Form -->
        <div id="form" class="glass-card rounded-xl p-6 sm:p-8 hidden">
          <h2 class="font-display font-semibold text-xl text-xv-text-primary mb-6">Send a message</h2>

          <form id="contact-form" class="space-y-5">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="name" class="block text-sm font-medium text-xv-text-secondary mb-1.5">Name</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full px-4 py-2.5 bg-xv-bg-primary border border-xv-border rounded-lg text-xv-text-primary text-sm placeholder:text-xv-text-muted focus:outline-none focus:border-xv-accent-blue/50 focus:ring-1 focus:ring-xv-accent-blue/20 transition-colors"
                  placeholder="Your name"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-xv-text-secondary mb-1.5">Email</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full px-4 py-2.5 bg-xv-bg-primary border border-xv-border rounded-lg text-xv-text-primary text-sm placeholder:text-xv-text-muted focus:outline-none focus:border-xv-accent-blue/50 focus:ring-1 focus:ring-xv-accent-blue/20 transition-colors"
                  placeholder="you@company.com"
                />
              </div>
            </div>

            <div>
              <label for="business-type" class="block text-sm font-medium text-xv-text-secondary mb-1.5">Business type</label>
              <select
                id="business-type"
                name="business-type"
                class="w-full px-4 py-2.5 bg-xv-bg-primary border border-xv-border rounded-lg text-xv-text-primary text-sm focus:outline-none focus:border-xv-accent-blue/50 focus:ring-1 focus:ring-xv-accent-blue/20 transition-colors"
              >
                <option value="" class="text-xv-text-muted">Select your industry</option>
                <option value="real-estate">Real Estate</option>
                <option value="service-business">Service Business</option>
                <option value="saas-tech">SaaS / Tech</option>
                <option value="ecommerce">E-commerce</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div>
              <label for="service" class="block text-sm font-medium text-xv-text-secondary mb-1.5">What do you need?</label>
              <select
                id="service"
                name="service"
                class="w-full px-4 py-2.5 bg-xv-bg-primary border border-xv-border rounded-lg text-xv-text-primary text-sm focus:outline-none focus:border-xv-accent-blue/50 focus:ring-1 focus:ring-xv-accent-blue/20 transition-colors"
              >
                <option value="" class="text-xv-text-muted">Select a service</option>
                <option value="website-build">Website Build</option>
                <option value="crm-setup">CRM Setup & Automation</option>
                <option value="ai-integration">AI Tool Integration</option>
                <option value="strategy-call">Strategy Call</option>
                <option value="other">Something Else</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-xv-text-secondary mb-1.5">Tell me more</label>
              <textarea
                id="message"
                name="message"
                rows="4"
                class="w-full px-4 py-2.5 bg-xv-bg-primary border border-xv-border rounded-lg text-xv-text-primary text-sm placeholder:text-xv-text-muted focus:outline-none focus:border-xv-accent-blue/50 focus:ring-1 focus:ring-xv-accent-blue/20 transition-colors resize-none"
                placeholder="What are you trying to build or solve? The more context, the better."
              ></textarea>
            </div>

            <button id="submit-btn" type="submit" class="btn-primary w-full justify-center">
              <span id="submit-label">Send Message</span>
              <svg id="submit-icon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
              </svg>
            </button>

            <div id="form-success" class="hidden text-center py-2">
              <p class="text-xv-accent-green font-medium text-sm">Message sent. I'll be in touch within 24 hours.</p>
            </div>
            <div id="form-error" class="hidden text-center py-2">
              <p class="text-red-400 text-sm">Something went wrong. Please try again or email directly.</p>
            </div>

            <p class="text-xs text-xv-text-muted text-center">
              I'll get back to you within 24 hours. Usually faster.
            </p>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  function showPanel(panel: string) {
    const book = document.getElementById('book');
    const form = document.getElementById('form');
    const btnBook = document.getElementById('btn-book');
    const btnForm = document.getElementById('btn-form');

    if (!book || !form || !btnBook || !btnForm) return;

    // Hide both panels first
    book.classList.add('hidden');
    form.classList.add('hidden');

    // Remove active highlight from both buttons
    btnBook.classList.remove('border-xv-accent-blue/40');
    btnForm.classList.remove('border-xv-accent-green/40');

    // Show selected panel and highlight its button
    if (panel === 'book') {
      book.classList.remove('hidden');
      btnBook.classList.add('border-xv-accent-blue/40');
      book.scrollIntoView({ behavior: 'smooth', block: 'start' });
    } else {
      form.classList.remove('hidden');
      btnForm.classList.add('border-xv-accent-green/40');
      form.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  }

  // Expose globally for inline onclick handlers
  (window as any).showPanel = showPanel;

  // Contact form submission
  const contactForm = document.getElementById('contact-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const submitLabel = document.getElementById('submit-label');
  const submitIcon = document.getElementById('submit-icon');
  const successMsg = document.getElementById('form-success');
  const errorMsg = document.getElementById('form-error');

  contactForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;

    // Loading state
    if (submitBtn) submitBtn.disabled = true;
    if (submitLabel) submitLabel.textContent = 'Sending…';
    if (submitIcon) submitIcon.classList.add('hidden');
    successMsg?.classList.add('hidden');
    errorMsg?.classList.add('hidden');

    const payload = {
      name: (form.elements.namedItem('name') as HTMLInputElement).value,
      email: (form.elements.namedItem('email') as HTMLInputElement).value,
      business_type: (form.elements.namedItem('business-type') as HTMLSelectElement).value,
      service: (form.elements.namedItem('service') as HTMLSelectElement).value,
      message: (form.elements.namedItem('message') as HTMLTextAreaElement).value,
    };

    try {
      await fetch('https://services.leadconnectorhq.com/hooks/fKNgkg4PDWsOfFTAOWYE/webhook-trigger/cd9f3d43-0726-4640-b166-56eea3dfc46a', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      form.reset();
      successMsg?.classList.remove('hidden');
    } catch {
      errorMsg?.classList.remove('hidden');
    } finally {
      if (submitBtn) submitBtn.disabled = false;
      if (submitLabel) submitLabel.textContent = 'Send Message';
      if (submitIcon) submitIcon.classList.remove('hidden');
    }
  });
</script>
