---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
---

<BaseLayout title="404 — Xovion Labs" description="Page not found">
  <section class="px-4 sm:px-6 py-32 min-h-[70vh] flex items-center justify-center">
    <div class="text-center max-w-lg">
      <!-- Terminal-style 404 -->
      <div class="inline-block p-6 bg-[#161B22] border border-[#21262D] rounded-xl font-mono text-sm mb-8 text-left">
        <div class="flex items-center gap-2 mb-3">
          <div class="w-3 h-3 rounded-full bg-[#FF5F57]"></div>
          <div class="w-3 h-3 rounded-full bg-[#FFBD2E]"></div>
          <div class="w-3 h-3 rounded-full bg-[#28C840]"></div>
        </div>
        <p><span class="text-[#7EE787]">$</span> <span class="text-[#E6EDF3]">navigate to {Astro.url.pathname}</span></p>
        <p class="text-[#FF5F57]">Error: 404 — page not found</p>
        <p class="text-[#8B949E]">// This URL doesn't exist</p>
        <p class="text-[#8B949E]">// Try one of the nav links above</p>
        <p><span class="text-[#D2A8FF]">▊</span></p>
      </div>

      <h1 class="text-4xl font-bold text-[#E6EDF3] mb-4">404</h1>
      <p class="text-[#8B949E] mb-8">
        This page doesn't exist. But the rest of the site does.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <Button href="/">Go Home</Button>
        <Button href="/services" variant="secondary">See Services</Button>
      </div>
    </div>
  </section>
</BaseLayout>
