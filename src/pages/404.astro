---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="404 - Page Not Found">
  <section class="section-padding flex items-center justify-center min-h-[60vh]">
    <div class="text-center">
      <p class="font-mono text-6xl font-bold gradient-text mb-4">404</p>
      <h1 class="font-display font-bold text-2xl text-xv-text-primary mb-2">Page not found</h1>
      <p class="text-xv-text-secondary mb-8">This page doesn't exist. Unlike our results.</p>
      <a href="/" class="btn-primary">
        Back to Home
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>
</BaseLayout>
