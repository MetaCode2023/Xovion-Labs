---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { services } from '@/data/services';

const colorMap: Record<string, { border: string; bg: string; text: string; gradientFrom: string }> = {
  blue:   { border: 'border-xv-accent-blue/20', bg: 'bg-xv-accent-blue/10', text: 'text-xv-accent-blue', gradientFrom: 'from-xv-accent-blue' },
  cyan:   { border: 'border-xv-accent-blue/20', bg: 'bg-xv-accent-blue/10', text: 'text-xv-accent-blue', gradientFrom: 'from-xv-accent-blue' },
  green:  { border: 'border-xv-accent-blue/20', bg: 'bg-xv-accent-blue/10', text: 'text-xv-accent-blue', gradientFrom: 'from-xv-accent-blue' },
  purple: { border: 'border-xv-accent-blue/20', bg: 'bg-xv-accent-blue/10', text: 'text-xv-accent-blue', gradientFrom: 'from-xv-accent-blue' },
};

const iconMap: Record<string, string> = {
  code: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" />`,
  workflow: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25a2.25 2.25 0 01-2.25-2.25v-2.25z" />`,
  plug: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" />`,
  compass: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />`,
  phone: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 6.75z" />`,
};
---

<BaseLayout title="Services" description="AI services for small businesses: custom website builds, CRM automation, AI agent integrations, and strategy consulting. Built by operators who run real businesses — not consultants.">
  <!-- Page header -->
  <section class="section-padding pb-12">
    <div class="section-container">
      <span class="tag-blue mb-4 block w-fit">Services</span>
      <h1 class="font-display font-bold text-4xl sm:text-5xl text-xv-text-primary tracking-tight">
        What we <span class="gradient-text">build.</span>
      </h1>
      <p class="mt-4 text-xv-text-secondary text-lg max-w-2xl">
        Five service pillars, all grounded in real experience. Every one of these is something we run inside our own businesses before we offer it to yours.
      </p>
    </div>
  </section>

  <!-- Service sections -->
  {services.map((service, i) => {
    const colors = colorMap[service.color];
    const isEven = i % 2 === 0;
    return (
      <section id={service.id} class:list={['py-16 md:py-24 scroll-mt-24', isEven ? '' : 'bg-xv-bg-secondary/20 border-y border-xv-border/20']}>
        <div class="section-container">
          <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16">
            {/* Left: Main content */}
            <div class="lg:col-span-7">
              <div class:list={['w-12 h-12 rounded-xl flex items-center justify-center mb-6', colors.bg, colors.border, 'border']}>
                <svg class:list={['w-6 h-6', colors.text]} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <Fragment set:html={iconMap[service.icon]} />
                </svg>
              </div>

              <h2 class="font-display font-bold text-2xl sm:text-3xl text-xv-text-primary tracking-tight mb-2">
                {service.title}
              </h2>
              <p class:list={['text-sm font-mono mb-6', colors.text]}>
                {service.tagline}
              </p>
              <p class="text-xv-text-secondary leading-relaxed mb-8">
                {service.description}
              </p>

              {/* Features */}
              <h3 class="font-display font-semibold text-sm uppercase tracking-wider text-xv-text-muted mb-4">What's included</h3>
              <ul class="space-y-3 mb-8">
                {service.features.map(feature => (
                  <li class="flex items-start gap-3">
                    <svg class:list={['w-4 h-4 mt-0.5 flex-shrink-0', colors.text]} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    <span class="text-sm text-xv-text-secondary">{feature}</span>
                  </li>
                ))}
              </ul>

              {service.id === 'ai-receptionist' ? (
                <div class="flex flex-wrap gap-3">
                  <a href="/ai-receptionist" class="btn-primary">
                    Hear It In Action
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                  </a>
                  <a href="/contact" class="btn-secondary">Book a Call</a>
                </div>
              ) : (
                <a href="/contact" class="btn-primary">
                  Get Started
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </a>
              )}
            </div>

            {/* Right: Proof + Ideal for */}
            <div class="lg:col-span-5 space-y-6">
              {/* Proof points */}
              <div class="glass-card rounded-xl p-6">
                <h3 class="font-display font-semibold text-sm uppercase tracking-wider text-xv-text-muted mb-4">Proof points</h3>
                <ul class="space-y-3">
                  {service.proofPoints.map(point => (
                    <li class="flex items-start gap-3">
                      <span class:list={['w-1.5 h-1.5 rounded-full mt-1.5 flex-shrink-0', colors.text.replace('text-', 'bg-')]}></span>
                      <span class="text-sm text-xv-text-secondary">{point}</span>
                    </li>
                  ))}
                </ul>
              </div>

              {/* Ideal for */}
              <div class="glass-card rounded-xl p-6">
                <h3 class="font-display font-semibold text-sm uppercase tracking-wider text-xv-text-muted mb-4">Ideal for</h3>
                <ul class="space-y-3">
                  {service.idealFor.map(item => (
                    <li class="flex items-start gap-3">
                      <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-xv-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0" />
                      </svg>
                      <span class="text-sm text-xv-text-secondary">{item}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        </div>
      </section>
    );
  })}

  <!-- How it works -->
  <section class="py-16 md:py-24 bg-xv-bg-secondary/20 border-y border-xv-border/20">
    <div class="section-container">
      <div class="text-center mb-12">
        <span class="tag-blue mb-4 block w-fit mx-auto">How it works</span>
        <h2 class="font-display font-bold text-3xl text-xv-text-primary tracking-tight">
          Simple. Ongoing. No surprises.
        </h2>
        <p class="mt-3 text-xv-text-secondary text-lg max-w-xl mx-auto">
          Everything we build is delivered under a flat monthly engagement — no large upfront costs, no per-hour billing, no surprise invoices.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
        <div class="glass-card rounded-xl p-6 text-center">
          <div class="w-10 h-10 rounded-full bg-xv-accent-blue/10 border border-xv-accent-blue/20 flex items-center justify-center mx-auto mb-4">
            <span class="font-display font-bold text-xv-accent-blue text-sm">01</span>
          </div>
          <h3 class="font-display font-semibold text-xv-text-primary mb-2">Free Strategy Call</h3>
          <p class="text-sm text-xv-text-secondary">We learn your business, identify the highest-leverage automation opportunities, and scope exactly what we'd build.</p>
        </div>
        <div class="glass-card rounded-xl p-6 text-center">
          <div class="w-10 h-10 rounded-full bg-xv-accent-cyan/10 border border-xv-accent-cyan/20 flex items-center justify-center mx-auto mb-4">
            <span class="font-display font-bold text-xv-accent-cyan text-sm">02</span>
          </div>
          <h3 class="font-display font-semibold text-xv-text-primary mb-2">We Build the Systems</h3>
          <p class="text-sm text-xv-text-secondary">Our team designs, builds, and deploys your AI automations — CRM pipelines, agents, workflows, web infrastructure — all handled for you.</p>
        </div>
        <div class="glass-card rounded-xl p-6 text-center">
          <div class="w-10 h-10 rounded-full bg-xv-accent-green/10 border border-xv-accent-green/20 flex items-center justify-center mx-auto mb-4">
            <span class="font-display font-bold text-xv-accent-green text-sm">03</span>
          </div>
          <h3 class="font-display font-semibold text-xv-text-primary mb-2">Monthly Engagement</h3>
          <p class="text-sm text-xv-text-secondary">Ongoing deliverables, system improvements, and support — every month. Flat fee. Cancel anytime. Your systems keep running either way.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="section-padding">
    <div class="section-container text-center max-w-2xl mx-auto">
      <h2 class="font-display font-bold text-3xl text-xv-text-primary tracking-tight">
        Not sure which service fits?
      </h2>
      <p class="mt-3 text-xv-text-secondary text-lg">
        Book a free call. We'll figure out together where AI can make the biggest impact in your business.
      </p>
      <a href="/contact" class="btn-primary mt-6 inline-flex">
        Book a Free Call
      </a>
    </div>
  </section>
</BaseLayout>
