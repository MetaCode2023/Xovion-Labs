---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: post,
  }));
}

const post = Astro.props;
const { Content } = await post.render();

const tagColorMap: Record<string, string> = {
  'AI Tools': 'tag-blue',
  'Web Development': 'tag-green',
  'Claude Code': 'tag-purple',
  'CRM': 'tag-cyan',
  'Real Estate': 'tag-amber',
  'Automation': 'tag-blue',
};
---

<BaseLayout title={post.data.title} description={post.data.description} type="article">
  <article class="section-padding">
    <div class="section-container max-w-3xl mx-auto">
      <!-- Post header -->
      <header class="mb-10">
        <div class="flex flex-wrap gap-2 mb-4">
          {post.data.tags.map(tag => (
            <span class={tagColorMap[tag] || 'tag-blue'}>{tag}</span>
          ))}
        </div>
        <h1 class="font-display font-bold text-3xl sm:text-4xl text-xv-text-primary tracking-tight text-balance">
          {post.data.title}
        </h1>
        <p class="mt-3 text-xv-text-secondary text-lg">{post.data.description}</p>
        <div class="mt-4 flex items-center gap-4 text-xs font-mono text-xv-text-muted">
          <time datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
          </time>
          <span>by {post.data.author}</span>
        </div>
        <div class="mt-6 h-px bg-xv-border/40"></div>
      </header>

      <!-- Post content -->
      <div class="prose prose-invert prose-lg max-w-none
        prose-headings:font-display prose-headings:font-bold prose-headings:tracking-tight
        prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4
        prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
        prose-p:text-xv-text-secondary prose-p:leading-relaxed
        prose-a:text-xv-accent-blue prose-a:no-underline hover:prose-a:underline
        prose-strong:text-xv-text-primary
        prose-code:text-xv-accent-cyan prose-code:bg-xv-bg-tertiary prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm
        prose-pre:bg-xv-bg-tertiary prose-pre:border prose-pre:border-xv-border prose-pre:rounded-xl
        prose-li:text-xv-text-secondary
        prose-blockquote:border-xv-accent-blue prose-blockquote:text-xv-text-secondary
        prose-img:rounded-xl
      ">
        <Content />
      </div>

      <!-- Post footer -->
      <footer class="mt-12 pt-8 border-t border-xv-border/40">
        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
          <a href="/blog" class="btn-secondary text-sm">
            <svg class="w-4 h-4 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
            Back to all posts
          </a>
          <a href="/contact" class="btn-primary text-sm">
            Have questions? Let's talk
          </a>
        </div>
      </footer>
    </div>
  </article>
</BaseLayout>
