---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/blog/PostCard.astro';
import { getCollection } from 'astro:content';
import GlowEffect from '../../components/ui/GlowEffect.astro';

const posts = await getCollection('blog', ({ data }) => !data.draft);
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();
---

<BaseLayout
  title="Blog — Xovion Labs"
  description="Practical guides on building with AI — websites, CRMs, automations, and real estate operations. Written from experience, not research."
>
  <section class="relative overflow-hidden px-4 sm:px-6 pt-16 pb-8 border-b border-[#21262D]">
    <GlowEffect color="purple" position="top-left" />
    <div class="max-w-6xl mx-auto relative z-10">
      <p class="text-xs font-mono text-[#58A6FF] uppercase tracking-widest mb-4">Blog / Learn</p>
      <h1 class="text-3xl sm:text-4xl font-bold text-[#E6EDF3] mb-4">
        Written from experience, not research
      </h1>
      <p class="text-[#8B949E] text-lg max-w-2xl">
        Every post references something actually built or done. No theoretical AI takes — just what works in real operations.
      </p>
    </div>
  </section>

  <section class="px-4 sm:px-6 py-12">
    <div class="max-w-6xl mx-auto">
      {allTags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-10">
          {allTags.map((tag) => (
            <span class="px-3 py-1 bg-[#161B22] border border-[#21262D] rounded-full text-xs font-mono text-[#8B949E] hover:text-[#E6EDF3] hover:border-[#58A6FF] transition-all cursor-default">
              {tag}
            </span>
          ))}
        </div>
      )}

      {posts.length === 0 ? (
        <div class="text-center py-20">
          <p class="text-[#8B949E] font-mono">// posts coming soon</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {posts.map((post) => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              slug={post.id}
              tags={post.data.tags}
              readingTime={post.data.readingTime}
            />
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- Newsletter signup -->
  <section class="px-4 sm:px-6 py-16 border-t border-[#21262D] bg-[#161B22]">
    <div class="max-w-xl mx-auto text-center">
      <p class="text-xs font-mono text-[#58A6FF] uppercase tracking-widest mb-4">Newsletter</p>
      <h2 class="text-2xl font-bold text-[#E6EDF3] mb-3">Get the good stuff in your inbox</h2>
      <p class="text-[#8B949E] mb-8">
        Practical AI workflows and build tutorials — 1-2x per month. No fluff.
      </p>
      <form class="flex flex-col sm:flex-row gap-3">
        <input
          type="email"
          placeholder="your@email.com"
          class="flex-1 px-4 py-3 bg-[#0D1117] border border-[#30363D] rounded-lg text-[#E6EDF3] placeholder-[#8B949E] focus:outline-none focus:border-[#58A6FF] font-mono text-sm"
        />
        <button
          type="submit"
          class="px-6 py-3 bg-[#58A6FF] text-[#0D1117] font-semibold rounded-lg hover:bg-[#79BAFF] transition-colors whitespace-nowrap text-sm"
        >
          Subscribe
        </button>
      </form>
    </div>
  </section>
</BaseLayout>
