---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Free CRM Audit Checklist — Xovion Labs"
  description="12 diagnostic questions that expose exactly where your pipeline is losing revenue. Used on real acquisition operations, not made up for a blog post."
>
  <section class="section-padding">
    <div class="section-container">
      <div class="max-w-2xl mx-auto">

        <!-- Header -->
        <div class="text-center mb-12">
          <span class="tag-green mb-4 inline-block">Free Resource</span>
          <h1 class="font-display font-bold text-4xl sm:text-5xl text-xv-text-primary tracking-tight text-balance">
            Is your pipeline hiding your
            <span class="gradient-text"> best leads?</span>
          </h1>
          <p class="mt-4 text-xv-text-secondary text-lg max-w-xl mx-auto">
            12 diagnostic questions that expose exactly where your CRM is losing revenue.
            Used on real acquisition operations — not made up for a blog post.
          </p>
        </div>

        <!-- What you get -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-10">
          {[
            { label: '12 diagnostic questions', sub: 'Across 4 pipeline categories' },
            { label: 'Scoring system', sub: 'Know how bad the leak actually is' },
            { label: 'Fix priorities', sub: 'What to tackle first' },
          ].map(item => (
            <div class="glass-card rounded-xl p-5 text-center">
              <p class="font-display font-semibold text-xv-text-primary text-sm">{item.label}</p>
              <p class="text-xv-text-muted text-xs mt-1">{item.sub}</p>
            </div>
          ))}
        </div>

        <!-- Form -->
        <div class="glass-card rounded-2xl p-8 sm:p-10" id="form-wrap">
          <h2 class="font-display font-semibold text-xl text-xv-text-primary mb-2">Get the checklist</h2>
          <p class="text-xv-text-secondary text-sm mb-6">
            Enter your email and it ships immediately. No course login. No drip sequence to wait through.
          </p>

          <form id="audit-form" class="space-y-4">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="name" class="block text-sm font-medium text-xv-text-secondary mb-1.5">Name</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  placeholder="Your name"
                  class="w-full px-4 py-2.5 bg-xv-bg-primary border border-xv-border rounded-lg text-xv-text-primary text-sm placeholder:text-xv-text-muted focus:outline-none focus:border-xv-accent-blue/50 focus:ring-1 focus:ring-xv-accent-blue/20 transition-colors"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-xv-text-secondary mb-1.5">Email</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  placeholder="you@company.com"
                  class="w-full px-4 py-2.5 bg-xv-bg-primary border border-xv-border rounded-lg text-xv-text-primary text-sm placeholder:text-xv-text-muted focus:outline-none focus:border-xv-accent-blue/50 focus:ring-1 focus:ring-xv-accent-blue/20 transition-colors"
                />
              </div>
            </div>

            <div>
              <label for="business-type" class="block text-sm font-medium text-xv-text-secondary mb-1.5">Business type</label>
              <select
                id="business-type"
                name="business_type"
                class="w-full px-4 py-2.5 bg-xv-bg-primary border border-xv-border rounded-lg text-xv-text-primary text-sm focus:outline-none focus:border-xv-accent-blue/50 focus:ring-1 focus:ring-xv-accent-blue/20 transition-colors"
              >
                <option value="">Select your industry</option>
                <option value="real-estate">Real Estate / Acquisitions</option>
                <option value="property-management">Property Management</option>
                <option value="service-business">Service Business</option>
                <option value="equipment-rental">Equipment Rental</option>
                <option value="other">Other</option>
              </select>
            </div>

            <button id="submit-btn" type="submit" class="btn-primary w-full justify-center">
              <span id="submit-label">Send Me the Checklist</span>
              <svg id="submit-icon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
              </svg>
            </button>

            <div id="form-success" class="hidden text-center py-2">
              <p class="text-xv-accent-green font-medium text-sm">Check your inbox — the checklist is on its way.</p>
            </div>
            <div id="form-error" class="hidden text-center py-2">
              <p class="text-red-400 text-sm">Something went wrong. Try again or email austin@xovionlabs.com directly.</p>
            </div>

            <p class="text-xs text-xv-text-muted text-center">
              No spam. Unsubscribe anytime. You'll also get the monthly Operator Brief.
            </p>
          </form>
        </div>

        <!-- Social proof -->
        <div class="mt-10 text-center">
          <p class="text-xv-text-muted text-sm">Built from auditing real pipelines across real estate, property management, and service businesses.</p>
          <div class="mt-6 flex flex-wrap justify-center gap-4 text-xs text-xv-text-muted font-mono">
            <span>Big Sioux Home Buyers</span>
            <span class="text-xv-border">·</span>
            <span>Metastone Properties</span>
            <span class="text-xv-border">·</span>
            <span>Dump Dynasty</span>
          </div>
        </div>

        <!-- Already know what you need? -->
        <div class="mt-12 text-center">
          <p class="text-xv-text-secondary text-sm">
            Already know your pipeline is broken?
            <a href="/contact" class="text-xv-accent-blue hover:underline ml-1">Book a 30-minute call →</a>
          </p>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('audit-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const submitLabel = document.getElementById('submit-label');
  const submitIcon = document.getElementById('submit-icon');
  const successMsg = document.getElementById('form-success');
  const errorMsg = document.getElementById('form-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const f = e.target as HTMLFormElement;

    if (submitBtn) submitBtn.disabled = true;
    if (submitLabel) submitLabel.textContent = 'Sending…';
    if (submitIcon) submitIcon.classList.add('hidden');
    successMsg?.classList.add('hidden');
    errorMsg?.classList.add('hidden');

    const payload = {
      name: (f.elements.namedItem('name') as HTMLInputElement).value,
      email: (f.elements.namedItem('email') as HTMLInputElement).value,
      business_type: (f.elements.namedItem('business_type') as HTMLSelectElement).value,
      source: 'crm-audit',
      tags: 'lead-magnet-crm-audit',
    };

    try {
      await fetch('https://services.leadconnectorhq.com/hooks/fKNgkg4PDWsOfFTAOWYE/webhook-trigger/cd9f3d43-0726-4640-b166-56eea3dfc46a', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      f.reset();
      successMsg?.classList.remove('hidden');
    } catch {
      errorMsg?.classList.remove('hidden');
    } finally {
      if (submitBtn) submitBtn.disabled = false;
      if (submitLabel) submitLabel.textContent = 'Send Me the Checklist';
      if (submitIcon) submitIcon.classList.remove('hidden');
    }
  });
</script>
