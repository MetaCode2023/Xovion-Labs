---
import SEO from '@/components/global/SEO.astro';
import Header from '@/components/global/Header.astro';
import Footer from '@/components/global/Footer.astro';
import ChatWidget from '@/components/ui/ChatWidget';
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
}

const { title, description, image, type } = Astro.props;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': 'https://xovionlabs.com/#organization',
      name: 'Xovion Labs',
      url: 'https://xovionlabs.com',
      logo: {
        '@type': 'ImageObject',
        url: 'https://xovionlabs.com/xovion_labs_logo.svg',
      },
      description:
        'Xovion Labs builds custom AI automation systems for small businesses — from website infrastructure and CRM pipelines to AI agents and workflow automation. Based in Sioux Falls, SD.',
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Sioux Falls',
        addressRegion: 'SD',
        addressCountry: 'US',
      },
      sameAs: [
        'https://www.facebook.com/profile.php?id=61573321545276',
        'https://github.com/MetaCode2023',
      ],
      knowsAbout: [
        'AI automation',
        'CRM implementation',
        'small business AI',
        'workflow automation',
        'website development',
        'AI consulting',
      ],
    },
    {
      '@type': 'LocalBusiness',
      '@id': 'https://xovionlabs.com/#localbusiness',
      name: 'Xovion Labs',
      url: 'https://xovionlabs.com',
      description:
        'AI implementation and automation services for small businesses. We build custom AI systems, CRM pipelines, and website infrastructure — powered by real operator experience.',
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Sioux Falls',
        addressRegion: 'SD',
        addressCountry: 'US',
      },
      priceRange: '$$',
      areaServed: {
        '@type': 'Country',
        name: 'United States',
      },
      hasOfferCatalog: {
        '@type': 'OfferCatalog',
        name: 'AI Services for Small Businesses',
        itemListElement: [
          { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'AI-Powered Website Builds' } },
          { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'CRM Architecture & Automation' } },
          { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'AI Orchestration & Custom Integrations' } },
          { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Operator Advisory & Blueprinting' } },
        ],
      },
    },
  ],
};
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <SEO title={title} description={description} image={image} type={type} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="min-h-screen flex flex-col noise-overlay">

    <!-- SVG Grain/Noise Overlay -->
    <div
      class="fixed inset-0 z-50 pointer-events-none select-none"
      style="opacity: 0.04;"
      aria-hidden="true"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%">
        <filter id="grain-filter">
          <feTurbulence
            type="fractalNoise"
            baseFrequency="0.65"
            numOctaves="3"
            stitchTiles="stitch"
          />
          <feColorMatrix type="saturate" values="0" />
        </filter>
        <rect width="100%" height="100%" filter="url(#grain-filter)" />
      </svg>
    </div>

    <!-- Mouse Spotlight -->
    <div
      id="mouse-spotlight"
      class="fixed inset-0 z-0 pointer-events-none"
      aria-hidden="true"
    ></div>

    <Header />
    <main class="flex-1 pt-16 md:pt-18 relative z-10">
      <slot />
    </main>
    <Footer />
    <ChatWidget client:load />

    <script>
      // Per-card spotlight: update --mouse-x / --mouse-y relative to each card
      document.querySelectorAll<HTMLElement>('.spotlight-card').forEach(card => {
        card.addEventListener('mousemove', (e: MouseEvent) => {
          const r = card.getBoundingClientRect();
          card.style.setProperty('--mouse-x', `${e.clientX - r.left}px`);
          card.style.setProperty('--mouse-y', `${e.clientY - r.top}px`);
        });
        card.addEventListener('mouseleave', () => {
          card.style.setProperty('--mouse-x', '-9999px');
          card.style.setProperty('--mouse-y', '-9999px');
        });
      });

      const spotlight = document.getElementById('mouse-spotlight');
      if (spotlight) {
        let ticking = false;
        document.addEventListener('mousemove', (e: MouseEvent) => {
          if (!ticking) {
            requestAnimationFrame(() => {
              spotlight!.style.opacity = '1';
              spotlight!.style.background = `radial-gradient(700px circle at ${e.clientX}px ${e.clientY}px, rgba(88,166,255,0.07), transparent 80%)`;
              ticking = false;
            });
            ticking = true;
          }
        });
        document.addEventListener('mouseleave', () => {
          spotlight!.style.opacity = '0';
        });
      }
    </script>
  </body>
</html>
