---
import { siteConfig } from '@/data/navigation';
import TerminalWindow from '@/components/home/TerminalWindow.astro';
---

<section class="relative overflow-hidden min-h-[90vh] flex items-center">
  <!-- Background effects -->
  <div class="absolute inset-0">
    <!-- Video background -->
    <video
      id="hero-bg-video"
      class="absolute inset-0 w-full h-full object-cover"
      autoplay
      loop
      muted
      playsinline
      preload="auto"
      poster="/hero-poster.svg"
      aria-hidden="true"
    >
      <source src="/Video_Generation_With_Color.mp4" type="video/mp4" />
    </video>

    <!-- Dark glass overlay -->
    <div class="absolute inset-0 bg-gradient-to-b from-xv-bg-primary/75 via-xv-bg-primary/55 to-xv-bg-primary/85 backdrop-blur-[1px]"></div>

    <!-- Tech grid (on top of video + overlay) -->
    <div class="absolute inset-0 bg-[linear-gradient(rgba(59,130,246,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(59,130,246,0.03)_1px,transparent_1px)] bg-[size:64px_64px] [mask-image:radial-gradient(ellipse_at_center,black_20%,transparent_70%)]"></div>
  </div>

  <div class="section-container relative z-10 py-20 md:py-32">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Left column: text & CTAs -->
      <div class="max-w-xl">

        <!-- Live Status Badge -->
        <div class="opacity-0 animate-fade-in-up mb-6">
          <span class="inline-flex items-center gap-2 bg-slate-900 border border-slate-800 rounded-full px-3 py-1">
            <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse shrink-0"></span>
            <span class="text-xs font-mono text-slate-400 tracking-wider">SYS_STATUS: ONLINE</span>
          </span>
        </div>

        <!-- Headline with decrypt animation -->
        <h1 class="opacity-0 animate-fade-in-up animate-delay-100 font-display font-bold text-5xl sm:text-6xl lg:text-7xl tracking-tight leading-[1.05]">
          <span id="decrypt-p1" class="text-xv-text-primary">Custom AI</span>
          <span id="decrypt-p2" class="block mt-1 labs-gradient-text">Infrastructure.</span>
        </h1>

        <!-- Tagline -->
        <p class="opacity-0 animate-fade-in-up animate-delay-200 my-8 text-3xl sm:text-4xl font-display font-semibold text-xv-text-secondary">
          Real Skills. <span class="text-xv-text-primary">Unreal Speed.</span>
        </p>

        <!-- Description -->
        <p class="opacity-0 animate-fade-in-up animate-delay-300 text-base sm:text-lg text-xv-text-secondary leading-relaxed max-w-lg">
          We don't build theory. Xovion Labs is the internal engineering arm for a portfolio of physical businesses. We engineer custom AI infrastructure because off-the-shelf SaaS is too slow and too rigid to run high-volume operations. We build these systems because our own revenue depends on them.
        </p>

        <!-- CTAs -->
        <div class="opacity-0 animate-fade-in-up animate-delay-400 mt-8 flex flex-wrap gap-3 items-center">
          <a id="magnetic-btn" href="/services" class="inline-flex items-center gap-2 px-5 py-3 rounded-lg font-semibold text-base text-white bg-gradient-to-b from-blue-500 to-blue-600 ring-1 ring-inset ring-white/20 shadow-lg shadow-blue-500/40 hover:shadow-blue-500/60 active:scale-95" style="will-change: transform;">
            See What We Build
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="/contact" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg font-medium text-sm text-slate-300 bg-white/5 ring-1 ring-inset ring-white/10 transition-all duration-200 hover:text-white hover:bg-white/10 active:scale-95">
            Book a Call
          </a>
        </div>
      </div>

      <!-- Right column: Terminal (desktop only) -->
      <div class="opacity-0 animate-fade-in-up animate-delay-500 hidden lg:flex items-center justify-center">
        <TerminalWindow />
      </div>

    </div>
  </div>
</section>

<script>
  // Pause video for users who prefer reduced motion
  const video = document.getElementById('hero-bg-video') as HTMLVideoElement | null;
  if (video && window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    video.pause();
  }

  const CHARS = 'X01#$%@&*!><[]{}|/\\^~';
  const DURATION = 700;
  const INTERVAL = 28;

  function decrypt(el: HTMLElement, finalText: string, startDelay = 0) {
    const len = finalText.length;
    const totalFrames = Math.ceil(DURATION / INTERVAL);
    let frame = 0;

    setTimeout(() => {
      const timer = setInterval(() => {
        const revealed = Math.floor((frame / totalFrames) * len);
        let out = '';
        for (let i = 0; i < len; i++) {
          if (finalText[i] === ' ') {
            out += ' ';
          } else if (i < revealed) {
            out += finalText[i];
          } else {
            out += CHARS[Math.floor(Math.random() * CHARS.length)];
          }
        }
        el.textContent = out;
        frame++;
        if (frame > totalFrames) {
          el.textContent = finalText;
          clearInterval(timer);
        }
      }, INTERVAL);
    }, startDelay);
  }

  const p1 = document.getElementById('decrypt-p1') as HTMLElement | null;
  const p2 = document.getElementById('decrypt-p2') as HTMLElement | null;

  if (p1 && p2) {
    // Wait for the fade-in-up animation to start (100ms delay on h1)
    decrypt(p1, 'Custom AI', 120);
    decrypt(p2, 'Infrastructure.', 200);
  }

  // Magnetic button
  const magnetBtn = document.getElementById('magnetic-btn') as HTMLElement | null;
  if (magnetBtn) {
    const PROXIMITY = 30;   // px outside button bounds to start attracting
    const STRENGTH  = 0.35; // how far the button moves (fraction of cursor offset from center)
    let isActive = false;

    document.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = magnetBtn.getBoundingClientRect();
      const cx = rect.left + rect.width  / 2;
      const cy = rect.top  + rect.height / 2;
      const dx = e.clientX - cx;
      const dy = e.clientY - cy;

      // Distance from cursor to nearest edge (negative = inside the button)
      const edgeX = Math.max(0, Math.abs(dx) - rect.width  / 2);
      const edgeY = Math.max(0, Math.abs(dy) - rect.height / 2);
      const dist  = Math.sqrt(edgeX ** 2 + edgeY ** 2);

      if (dist < PROXIMITY) {
        if (!isActive) {
          // Entering: fast follow
          magnetBtn.style.transition = 'transform 0.12s ease-out, box-shadow 0.2s ease';
          isActive = true;
        }
        magnetBtn.style.transform = `translate(${dx * STRENGTH}px, ${dy * STRENGTH}px)`;
      } else if (isActive) {
        // Leaving: bouncy spring snap-back
        magnetBtn.style.transition = 'transform 0.65s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.2s ease';
        magnetBtn.style.transform  = 'translate(0px, 0px)';
        isActive = false;
      }
    });
  }
</script>
