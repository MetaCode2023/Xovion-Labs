---
import Button from '../ui/Button.astro';
import GlowEffect from '../ui/GlowEffect.astro';
---

<section class="relative overflow-hidden px-4 sm:px-6 pt-20 pb-24 sm:pt-28 sm:pb-32">
  <GlowEffect color="blue" position="top-right" />
  <GlowEffect color="purple" position="top-left" />

  <div class="max-w-6xl mx-auto relative z-10">
    <div class="max-w-3xl">
      <!-- Terminal badge -->
      <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-[#161B22] border border-[#21262D] rounded-full mb-8">
        <span class="w-2 h-2 rounded-full bg-[#7EE787] animate-pulse"></span>
        <span class="text-xs font-mono text-[#8B949E]">AI education + services — now live</span>
      </div>

      <!-- Heading -->
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight mb-6">
        <span class="font-mono text-[#E6EDF3]">XOVION</span>
        <span class="font-mono text-[#58A6FF]">_</span>
        <span class="font-mono text-[#E6EDF3]">LABS</span>
        <br />
        <span class="text-3xl sm:text-4xl lg:text-5xl text-[#8B949E] font-normal italic">
          Real Skills. Unreal Speed.
        </span>
      </h1>

      <!-- Subheading -->
      <p class="text-lg sm:text-xl text-[#8B949E] leading-relaxed mb-10 max-w-2xl">
        We build with AI every day across real businesses — real estate, property management, service companies.
        Not theory. Not demos. <span class="text-[#E6EDF3]">Actual AI-powered operations.</span>
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4">
        <Button href="/services" size="lg">
          See What We Build
        </Button>
        <Button href="/contact" variant="secondary" size="lg">
          Book a Call
        </Button>
      </div>

      <!-- Code snippet decoration -->
      <div class="mt-12 p-4 bg-[#161B22] border border-[#21262D] rounded-xl font-mono text-sm max-w-lg">
        <div class="flex items-center gap-2 mb-3">
          <div class="w-3 h-3 rounded-full bg-[#FF5F57]"></div>
          <div class="w-3 h-3 rounded-full bg-[#FFBD2E]"></div>
          <div class="w-3 h-3 rounded-full bg-[#28C840]"></div>
          <span class="ml-2 text-xs text-[#8B949E]">xovion-labs ~ terminal</span>
        </div>
        <div class="space-y-1">
          <p><span class="text-[#7EE787]">$</span> <span class="text-[#58A6FF]">build</span> <span class="text-[#E6EDF3]">--with ai --ship-fast</span></p>
          <p class="text-[#8B949E]">✓ Website deployed in 4 hours</p>
          <p class="text-[#8B949E]">✓ CRM pipeline live — 22 statuses</p>
          <p class="text-[#8B949E]">✓ SMS campaign: 13,000 texts/week</p>
          <p><span class="text-[#7EE787]">✓ Done.</span> <span class="text-[#D2A8FF] animate-pulse">▊</span></p>
        </div>
      </div>
    </div>
  </div>
</section>
