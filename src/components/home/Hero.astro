---
import { siteConfig } from '@/data/navigation';
import TerminalWindow from '@/components/home/TerminalWindow.astro';
---

<section class="relative overflow-hidden min-h-[90vh] flex items-center">
  <!-- Background effects -->
  <div class="absolute inset-0">
    <!-- Video background -->
    <video
      id="hero-bg-video"
      class="absolute inset-0 w-full h-full object-cover"
      autoplay
      loop
      muted
      playsinline
      preload="auto"
      poster="/hero-poster.svg"
      aria-hidden="true"
    >
      <source src="/Video_Generation_With_Color.mp4" type="video/mp4" />
    </video>

    <!-- Dark glass overlay -->
    <div class="absolute inset-0 bg-gradient-to-b from-xv-bg-primary/60 via-xv-bg-primary/35 to-xv-bg-primary/80"></div>
  </div>

  <div class="section-container relative z-10 py-20 md:py-28 w-full">

    <!-- Status Badge -->
    <div class="opacity-0 animate-fade-in-up mb-6">
      <span class="inline-flex items-center gap-2 bg-slate-900 border border-slate-800 rounded-full px-3 py-1">
        <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse shrink-0"></span>
        <span class="text-xs font-mono text-slate-400 tracking-wider">Now accepting new clients</span>
      </span>
    </div>

    <!-- Full-width headline -->
    <h1 class="opacity-0 animate-fade-in-up animate-delay-100 font-display font-extrabold text-5xl sm:text-6xl lg:text-7xl xl:text-8xl tracking-tight leading-[1.05] sm:leading-[1.0] lg:leading-[0.95] mb-10 lg:mb-14">
      <span class="text-xv-text-primary">We Turn LLMs Into</span>
      <span class="block text-xv-text-primary">Business Operators,</span>
      <span class="block gradient-text">Not Just Chatbots.</span>
    </h1>

    <!-- Bottom row: copy + terminal -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-start">

      <!-- Left: tagline, description, CTAs -->
      <div class="opacity-0 animate-fade-in-up animate-delay-200 max-w-lg">
        <p class="text-lg sm:text-xl font-display font-semibold text-xv-text-secondary mb-5">
          Fair warning — when you call us, you're talking to an AI. But it's built for this.
        </p>
        <p class="text-base sm:text-lg text-xv-text-secondary leading-relaxed mb-8">
          We build AI systems that take real actions — answering phones, booking jobs, updating your CRM, dispatching follow-ups — without a human in the loop. Systems we run inside our own businesses first, then bring to yours.
        </p>
        <div class="flex flex-wrap gap-3 items-center">
          <a id="magnetic-btn" href="/ai-receptionist" class="inline-flex items-center gap-2 px-5 py-3 rounded-lg font-semibold text-base text-white bg-gradient-to-b from-blue-500 to-blue-600 ring-1 ring-inset ring-white/20 shadow-lg shadow-blue-500/40 hover:shadow-blue-500/60 active:scale-95" style="will-change: transform;">
            Hear It For Yourself
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="/contact" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg font-medium text-sm text-slate-300 bg-white/5 ring-1 ring-inset ring-white/10 transition-all duration-200 hover:text-white hover:bg-white/10 active:scale-95">
            Book a Free Call
          </a>
        </div>
      </div>

      <!-- Right: Terminal (desktop only) -->
      <div class="opacity-0 animate-fade-in-up animate-delay-300 hidden lg:flex items-start justify-center">
        <TerminalWindow />
      </div>

    </div>
  </div>
</section>

<script>
  // Pause video for users who prefer reduced motion
  const video = document.getElementById('hero-bg-video') as HTMLVideoElement | null;
  if (video && window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    video.pause();
  }

  // Magnetic button
  const magnetBtn = document.getElementById('magnetic-btn') as HTMLElement | null;
  if (magnetBtn) {
    const PROXIMITY = 30;   // px outside button bounds to start attracting
    const STRENGTH  = 0.35; // how far the button moves (fraction of cursor offset from center)
    let isActive = false;

    document.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = magnetBtn.getBoundingClientRect();
      const cx = rect.left + rect.width  / 2;
      const cy = rect.top  + rect.height / 2;
      const dx = e.clientX - cx;
      const dy = e.clientY - cy;

      // Distance from cursor to nearest edge (negative = inside the button)
      const edgeX = Math.max(0, Math.abs(dx) - rect.width  / 2);
      const edgeY = Math.max(0, Math.abs(dy) - rect.height / 2);
      const dist  = Math.sqrt(edgeX ** 2 + edgeY ** 2);

      if (dist < PROXIMITY) {
        if (!isActive) {
          // Entering: fast follow
          magnetBtn.style.transition = 'transform 0.12s ease-out, box-shadow 0.2s ease';
          isActive = true;
        }
        magnetBtn.style.transform = `translate(${dx * STRENGTH}px, ${dy * STRENGTH}px)`;
      } else if (isActive) {
        // Leaving: bouncy spring snap-back
        magnetBtn.style.transition = 'transform 0.65s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.2s ease';
        magnetBtn.style.transform  = 'translate(0px, 0px)';
        isActive = false;
      }
    });
  }
</script>
