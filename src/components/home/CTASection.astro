---

---

<section class="section-padding relative overflow-hidden">
  <!-- Section top glow line -->
  <div class="absolute top-0 left-1/4 right-1/4 h-px bg-gradient-to-r from-transparent via-xv-accent-cyan/25 to-transparent" aria-hidden="true"></div>

  <!-- Background glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-xv-accent-cyan/5 rounded-full blur-[120px] pointer-events-none" aria-hidden="true"></div>

  <div class="section-container relative z-10">
    <div class="bg-xv-bg-secondary border border-xv-border rounded-2xl p-8 sm:p-12 md:p-16 text-center max-w-3xl mx-auto relative overflow-hidden">
      <!-- Inner top accent -->
      <div class="absolute top-0 left-1/4 right-1/4 h-px bg-gradient-to-r from-transparent via-xv-accent-cyan/40 to-transparent" aria-hidden="true"></div>

      <h2 class="font-display font-bold text-3xl sm:text-4xl text-xv-text-primary tracking-tight text-balance">
        Ready to build something
        <span class="gradient-text"> that works?</span>
      </h2>
      <p class="mt-4 text-slate-400 text-base sm:text-lg max-w-lg mx-auto">
        Whether you need a website, a CRM overhaul, or just want to figure out where AI fits in your business — let's talk.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <a href="/contact" class="btn-primary text-base">
          Book a Free Call
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href="/blog" class="btn-secondary text-base">
          Read the Blog
        </a>
      </div>
      <p class="mt-6 text-xs font-mono text-xv-text-muted">
        No pitch decks. No 47-slide proposals. Just a conversation about what you need.
      </p>
    </div>
  </div>
</section>
