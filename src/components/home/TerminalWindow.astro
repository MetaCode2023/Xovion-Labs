---
// TerminalWindow.astro — Animated skunkworks terminal display
---

<div class="w-full max-w-lg rounded-xl shadow-2xl shadow-black/60 border border-white/5 overflow-hidden">
  <!-- Title bar -->
  <div class="flex items-center gap-2 px-4 py-3 bg-[#1C1F26] border-b border-white/5">
    <div class="flex gap-1.5">
      <span class="w-3 h-3 rounded-full bg-[#FF5F57]"></span>
      <span class="w-3 h-3 rounded-full bg-[#FFBD2E]"></span>
      <span class="w-3 h-3 rounded-full bg-[#28C840]"></span>
    </div>
    <span class="flex-1 text-center text-xs text-[#5C6478] font-mono pr-10">xovion — zsh</span>
  </div>

  <!-- Terminal body -->
  <div class="bg-[#0D1017] p-5 min-h-[220px] font-mono text-sm leading-relaxed">
    <!-- Static prompt line -->
    <div class="mb-2">
      <span style="color: #34D399;">xovion</span><span style="color: #5C6478;">@</span><span style="color: #58A6FF;">ops</span><span style="color: #5C6478;"> ~ </span>
    </div>

    <!-- Dynamic output area -->
    <div id="xv-terminal-output"></div>

    <!-- Blinking cursor -->
    <span id="xv-terminal-cursor" class="xv-cursor"></span>
  </div>
</div>

<style is:global>
  @keyframes xv-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
  .xv-cursor {
    display: inline-block;
    width: 0.5rem;
    height: 1rem;
    background-color: #58A6FF;
    vertical-align: middle;
    animation: xv-blink 1s step-end infinite;
  }
  .xv-line-cmd  { color: #E8ECF4; }
  .xv-line-info { color: #8892A6; }
  .xv-line-ok   { color: #4ade80; }
</style>

<script>
  (function () {
    const outputEl = document.getElementById('xv-terminal-output');
    const cursorEl = document.getElementById('xv-terminal-cursor');
    if (!outputEl || !cursorEl) return;

    const COMMAND = '> claude "scan Close CRM for leads stalled over 30 days and build an n8n workflow to trigger a reactivation SMS sequence"';

    interface Step {
      type: 'type' | 'pause' | 'print';
      text?: string;
      cls?: string;
      ms?: number;
    }

    const sequence: Step[] = [
      { type: 'type',  text: COMMAND,                                                        cls: 'xv-line-cmd'  },
      { type: 'pause', ms: 800 },
      { type: 'print', text: '[Querying Close API... 412 stalled leads found]',               cls: 'xv-line-info' },
      { type: 'pause', ms: 600 },
      { type: 'print', text: '[Generating architecture... mapping webhooks...]',              cls: 'xv-line-info' },
      { type: 'pause', ms: 1000 },
      { type: 'print', text: '✓ Infrastructure deployed. Reactivation sequence active.',      cls: 'xv-line-ok'   },
    ];

    const sleep = (ms: number) => new Promise<void>(r => setTimeout(r, ms));

    function appendLine(text: string, cls: string) {
      const div = document.createElement('div');
      div.className = cls;
      div.textContent = text;
      outputEl!.appendChild(div);
    }

    async function typeText(text: string, cls: string) {
      const div = document.createElement('div');
      div.className = cls;
      outputEl!.appendChild(div);
      for (let i = 0; i < text.length; i++) {
        div.textContent = text.slice(0, i + 1);
        const ch = text[i];
        const delay = ch === ' ' ? 38 : (ch === '"' || ch === "'") ? 75 : Math.random() * 55 + 18;
        await sleep(delay);
      }
    }

    async function run() {
      outputEl!.innerHTML = '';
      cursorEl!.style.display = 'inline-block';

      for (const step of sequence) {
        if (step.type === 'type')  await typeText(step.text!, step.cls!);
        else if (step.type === 'pause') await sleep(step.ms!);
        else if (step.type === 'print') appendLine(step.text!, step.cls!);
      }

      // Idle 5s then loop
      await sleep(5000);
      run();
    }

    setTimeout(run, 900);
  })();
</script>
