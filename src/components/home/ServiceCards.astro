---
import { services } from '../../data/services';
import Card from '../ui/Card.astro';
---

<section class="px-4 sm:px-6 py-16 sm:py-24 border-t border-[#21262D]">
  <div class="max-w-6xl mx-auto">
    <div class="mb-12">
      <p class="text-xs font-mono text-[#58A6FF] uppercase tracking-widest mb-3">What We Do</p>
      <h2 class="text-2xl sm:text-3xl font-bold text-[#E6EDF3]">Four ways to build faster with AI</h2>
      <p class="mt-3 text-[#8B949E] max-w-xl">
        Each service is grounded in real operations — not courses built by people who've never run a business.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {services.map((service) => (
        <a href={`/services#${service.id}`} class="block group">
          <Card class="h-full group-hover:border-[#58A6FF] transition-colors">
            <div class="text-3xl mb-4">{service.icon}</div>
            <h3 class="text-base font-semibold text-[#E6EDF3] mb-2 group-hover:text-[#58A6FF] transition-colors">
              {service.title}
            </h3>
            <p class="text-sm text-[#8B949E] leading-relaxed">
              {service.tagline}
            </p>
            <div class="mt-4 flex items-center gap-1 text-xs font-mono text-[#58A6FF] opacity-0 group-hover:opacity-100 transition-opacity">
              <span>Learn more</span>
              <span>→</span>
            </div>
          </Card>
        </a>
      ))}
    </div>

    <div class="mt-8 text-center">
      <a
        href="/services"
        class="text-sm font-mono text-[#8B949E] hover:text-[#58A6FF] transition-colors"
      >
        View all services with proof points →
      </a>
    </div>
  </div>
</section>
