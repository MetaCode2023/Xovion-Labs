---
import { tools } from '../../data/tools';

const categories = [...new Set(tools.map((t) => t.category))];
---

<section class="px-4 sm:px-6 py-16 border-t border-[#21262D] bg-[#161B22]">
  <div class="max-w-4xl mx-auto">
    <p class="text-xs font-mono text-[#58A6FF] uppercase tracking-widest mb-3">Tool Stack</p>
    <h2 class="text-2xl font-bold text-[#E6EDF3] mb-2">What I actually use daily</h2>
    <p class="text-[#8B949E] mb-10">Not what I recommend in a blog post — what's open on my screen right now.</p>

    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
      {tools.map((tool) => (
        <div class="bg-[#0D1117] border border-[#21262D] rounded-lg p-3 hover:border-[#58A6FF]/40 transition-colors group">
          <div class="flex items-center gap-2 mb-2">
            <span class="text-lg">{tool.icon}</span>
            <span class="text-sm font-medium text-[#E6EDF3] group-hover:text-[#58A6FF] transition-colors">
              {tool.name}
            </span>
          </div>
          <span class="text-xs font-mono text-[#D2A8FF] bg-[#D2A8FF]/10 px-1.5 py-0.5 rounded">
            {tool.category}
          </span>
          <p class="text-xs text-[#8B949E] mt-2 leading-snug">{tool.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
