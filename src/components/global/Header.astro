---
import { navLinks, siteConfig } from '@/data/navigation';

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-xv-border/40 bg-xv-bg-primary/80 backdrop-blur-xl" id="site-header">
  <div class="section-container">
    <nav class="flex items-center justify-between py-3">
      <!-- Logo -->
      <a href="/" class="flex items-center group">
        <img
          src="/xovion_labs_logo.svg"
          alt="Xovion Labs"
          class="h-9 w-auto transition-opacity duration-200 group-hover:opacity-80"
        />
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-1">
        {navLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              'px-4 py-2.5 text-base font-semibold rounded-lg transition-all duration-200',
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'text-xv-accent-blue bg-xv-accent-blue/10'
                : 'text-xv-text-secondary hover:text-xv-text-primary hover:bg-xv-bg-tertiary/50',
            ]}
          >
            {link.label}
          </a>
        ))}
        <a href="/contact" class="ml-3 btn-primary text-sm !px-4 !py-2">
          Let's Build
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 text-xv-text-secondary hover:text-xv-text-primary transition-colors"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg id="menu-icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 9h16.5m-16.5 6.75h16.5" />
        </svg>
        <svg id="menu-icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </nav>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="md:hidden hidden border-t border-xv-border/40 bg-xv-bg-primary/95 backdrop-blur-xl">
    <div class="section-container py-4 flex flex-col gap-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={[
            'px-4 py-3 text-base font-semibold rounded-lg transition-colors',
            currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
              ? 'text-xv-accent-blue bg-xv-accent-blue/10'
              : 'text-xv-text-secondary hover:text-xv-text-primary hover:bg-xv-bg-tertiary/50',
          ]}
        >
          {link.label}
        </a>
      ))}
      <a href="/contact" class="btn-primary text-sm mt-2 justify-center">
        Let's Build
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
  });

  // Close on navigation
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      btn?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
