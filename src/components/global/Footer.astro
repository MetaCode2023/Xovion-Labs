---
import { navLinks, siteConfig } from '@/data/navigation';
---

<footer class="border-t border-xv-border/40 bg-xv-bg-secondary/30">
  <div class="section-container py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-8">
      <!-- Brand -->
      <div class="md:col-span-5">
        <a href="/" class="flex items-center gap-2.5 group mb-4">
          <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-xv-accent-blue to-xv-accent-cyan flex items-center justify-center">
            <span class="text-white font-mono font-bold text-sm">X</span>
          </div>
          <span class="font-display font-bold text-xv-text-primary text-lg tracking-wide">
            {siteConfig.name}
          </span>
        </a>
        <p class="text-xv-text-secondary text-sm leading-relaxed max-w-sm">
          {siteConfig.description}
        </p>
      </div>

      <!-- Navigation -->
      <div class="md:col-span-3">
        <h4 class="font-display font-semibold text-xv-text-primary text-sm uppercase tracking-wider mb-4">Navigate</h4>
        <div class="flex flex-col gap-2.5">
          {navLinks.map(link => (
            <a href={link.href} class="text-sm text-xv-text-secondary hover:text-xv-accent-blue transition-colors">
              {link.label}
            </a>
          ))}
        </div>
      </div>

      <!-- Services -->
      <div class="md:col-span-4">
        <h4 class="font-display font-semibold text-xv-text-primary text-sm uppercase tracking-wider mb-4">Services</h4>
        <div class="flex flex-col gap-2.5">
          <a href="/services#website-builds" class="text-sm text-xv-text-secondary hover:text-xv-accent-blue transition-colors">Website Builds</a>
          <a href="/services#crm-automation" class="text-sm text-xv-text-secondary hover:text-xv-accent-blue transition-colors">CRM & Automation</a>
          <a href="/services#ai-integration" class="text-sm text-xv-text-secondary hover:text-xv-accent-blue transition-colors">AI Integration</a>
          <a href="/services#ai-strategy" class="text-sm text-xv-text-secondary hover:text-xv-accent-blue transition-colors">AI Strategy</a>
        </div>
      </div>
    </div>

    <!-- Newsletter -->
    <div class="md:col-span-12 mt-2">
      <div class="glass-card rounded-xl p-6 flex flex-col sm:flex-row sm:items-center gap-4">
        <div class="flex-1">
          <p class="font-display font-semibold text-xv-text-primary text-sm">The Operator Brief</p>
          <p class="text-xv-text-muted text-xs mt-0.5">Monthly AI workflows and operator insights. No pitch content.</p>
        </div>
        <form id="footer-newsletter-form" class="flex gap-2 w-full sm:w-auto">
          <input
            type="email"
            id="footer-email"
            name="email"
            placeholder="your@email.com"
            required
            class="flex-1 sm:w-48 px-3 py-2 bg-xv-bg-primary border border-xv-border rounded-lg text-xv-text-primary text-xs placeholder:text-xv-text-muted focus:outline-none focus:border-xv-accent-blue/50 transition-colors"
          />
          <button
            id="footer-submit"
            type="submit"
            class="px-4 py-2 bg-xv-accent-blue text-xv-bg-primary font-semibold text-xs rounded-lg hover:bg-xv-accent-blue/80 transition-colors whitespace-nowrap"
          >
            Subscribe
          </button>
        </form>
        <p id="footer-success" class="hidden text-xs text-xv-accent-green sm:absolute">You're in.</p>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-xv-border/40 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-xv-text-muted">
        &copy; {new Date().getFullYear()} {siteConfig.name}. Built with AI. Refined by hand.
      </p>
      <div class="flex items-center gap-1">
        <span class="text-xs text-xv-text-muted font-mono">{siteConfig.tagline}</span>
      </div>
    </div>
  </div>
</footer>

<script>
  const form = document.getElementById('footer-newsletter-form') as HTMLFormElement | null;
  const emailInput = document.getElementById('footer-email') as HTMLInputElement | null;
  const submitBtn = document.getElementById('footer-submit') as HTMLButtonElement | null;
  const successMsg = document.getElementById('footer-success');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (submitBtn) submitBtn.disabled = true;
    if (submitBtn) submitBtn.textContent = '…';

    try {
      await fetch(
        'https://services.leadconnectorhq.com/hooks/fKNgkg4PDWsOfFTAOWYE/webhook-trigger/cd9f3d43-0726-4640-b166-56eea3dfc46a',
        {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email: emailInput?.value,
            source: 'footer-newsletter',
            tags: 'newsletter-subscriber',
          }),
        }
      );
      form.reset();
      form.classList.add('hidden');
      successMsg?.classList.remove('hidden');
    } catch {
      if (submitBtn) submitBtn.disabled = false;
      if (submitBtn) submitBtn.textContent = 'Subscribe';
    }
  });
</script>
