---
import { navLinks } from '../../data/navigation';
---

<footer class="border-t border-[#21262D] bg-[#0D1117]">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
      <!-- Brand -->
      <div>
        <a href="/" class="font-mono font-bold text-lg text-[#E6EDF3]">
          XOVION<span class="text-[#58A6FF]">_</span>LABS
        </a>
        <p class="mt-2 text-sm text-[#8B949E] italic">Real Skills. Unreal Speed.</p>
        <p class="mt-4 text-sm text-[#8B949E]">
          AI education and services for builders and operators.
        </p>
      </div>

      <!-- Nav -->
      <div>
        <h4 class="text-xs font-semibold text-[#8B949E] uppercase tracking-wider mb-4">Navigation</h4>
        <ul class="space-y-2">
          {navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-[#8B949E] hover:text-[#58A6FF] transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- CTA -->
      <div>
        <h4 class="text-xs font-semibold text-[#8B949E] uppercase tracking-wider mb-4">Get Started</h4>
        <p class="text-sm text-[#8B949E] mb-4">
          Ready to build something real with AI?
        </p>
        <a
          href="/contact"
          class="inline-block px-5 py-2.5 bg-[#58A6FF] text-[#0D1117] text-sm font-semibold rounded-lg hover:bg-[#79BAFF] transition-colors"
        >
          Book a Call
        </a>
      </div>
    </div>

    <div class="border-t border-[#21262D] pt-6 flex flex-col sm:flex-row items-center justify-between gap-2">
      <p class="text-xs text-[#8B949E] font-mono">
        © {new Date().getFullYear()} Xovion Labs. Built with Claude Code.
      </p>
      <p class="text-xs text-[#8B949E]">
        Real Skills. Unreal Speed.
      </p>
    </div>
  </div>
</footer>
