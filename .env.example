# ── Anthropic ─────────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── GoHighLevel Sub-Account ────────────────────────────────────────────────────
# Location API Key: GHL sub-account → Settings → Integrations → API Keys
GHL_API_KEY=

# Location ID: GHL sub-account → Settings → Business Profile → scroll to bottom
GHL_LOCATION_ID=

# Calendar ID: GHL sub-account → Calendars → (your discovery call calendar) → Settings → scroll to Calendar ID
GHL_CALENDAR_ID=

# ── Local dev notes ───────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# In production, add these as Cloudflare Pages environment variables:
#   CF Dashboard → Pages → xovion-labs → Settings → Environment Variables
